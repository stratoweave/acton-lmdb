"""LMDB

You must not open the same LMDB database multiple times within the same process.
This is a limitation of LMDB itself, as it is using advisory file locks to
manage concurrent access and this breaks down if the same process opens the
same DB multiple times.
"""
import file
import testing

class LMDBError(Exception):
    pass

class LMDBKeyError(LMDBError):
    """Key not found in database"""
    pass

class LMDBKeySizeError(LMDBError):
    """Key size exceeds maximum allowed size"""
    key: bytes
    max_size: int

    def __init__(self, key: bytes, max_size: int):
        self.key = key
        self.max_size = max_size
        self.error_message = "Key size exceeds maximum"

    def __str__(self) -> str:
        return "Key size {len(self.key)} exceeds maximum {self.max_size}"

def version() -> str:
    """Get LMDB version
    """
    NotImplemented

actor Db(cap: file.WriteFileCap, path: str, max_size: int=10485760):
    """LMDB Database actor

    Do NOT open the same LMDB database multiple times, concurrently, within the
    same process. This is a limitation of LMDB itself, as it is using advisory
    file locks to manage concurrent access and this breaks down if the same
    process opens the same DB multiple times.
    """
    var _env: int = 0  # Will hold pointer to MDB_env
    var _dbi: int = 0  # Will hold database handle
    var _max_key_size: int = 0  # Maximum allowed key size
    var _is_open: bool = False
    var _read_txn_count: int = 0
    var _write_txn_active: bool = False  # Track if write transaction is active
    var _write_txn_waiters: list[action(?Exception, ?WriteTransaction) -> None] = []

    def open():
        if _is_open:
            raise LMDBError("Database already open")
        res = _env_create_and_open(path, max_size)
        _env = res.0
        _dbi = res.1
        _max_key_size = res.2
        _is_open = True

    open()

    def put(key: bytes, value: bytes) -> None:
        if not _is_open:
            raise LMDBError("Database is closed")
        if _write_txn_active:
            raise LMDBError("Cannot use Db.put while write transaction is active")
        if len(key) > _max_key_size:
            raise LMDBKeySizeError(key, _max_key_size)
        _put(_env, _dbi, key, value)

    def get(key: bytes) -> ?bytes:
        if not _is_open:
            raise LMDBError("Database is closed")
        if len(key) > _max_key_size:
            raise LMDBKeySizeError(key, _max_key_size)
        return _get(_env, _dbi, key)

    def delete(key: bytes) -> bool:
        if not _is_open:
            raise LMDBError("Database is closed")
        if _write_txn_active:
            raise LMDBError("Cannot use Db.delete while write transaction is active")
        if len(key) > _max_key_size:
            raise LMDBKeySizeError(key, _max_key_size)
        return _delete(_env, _dbi, key)

    def close():
        if _is_open:
            if _read_txn_count > 0 or _write_txn_active or len(_write_txn_waiters) > 0:
                raise LMDBError("Cannot close database while transactions are active")
            _close(_env, _dbi)
            _is_open = False

    def __cleanup__():
        close()

    def begin_read() -> ReadTransaction:
        if not _is_open:
            raise LMDBError("Database is closed")
        _read_txn_count += 1

        def release_txn():
            if _read_txn_count > 0:
                _read_txn_count -= 1

        try:
            return ReadTransaction(_env, _dbi, release_txn)
        except Exception as e:
            release_txn()
            raise e

    def _new_write_txn() -> WriteTransaction:
        _write_txn_active = True

        def release_txn():
            _write_txn_active = False
            _dispatch_waiting_write_txn()

        try:
            return WriteTransaction(_env, _dbi, _max_key_size, release_txn)
        except Exception as e:
            _write_txn_active = False
            raise e

    def _dispatch_waiting_write_txn() -> None:
        if _is_open and not _write_txn_active and len(_write_txn_waiters) > 0:
            done = _write_txn_waiters.pop(0)
            try:
                done(None, _new_write_txn())
            except Exception as e:
                done(e, None)
                _dispatch_waiting_write_txn()

    def begin_write() -> WriteTransaction:
        """Begin a read-write transaction
        Only one allowed at a time, so the WriteTransaction must call release_txn
        """
        if not _is_open:
            raise LMDBError("Database is closed")
        if _write_txn_active or len(_write_txn_waiters) > 0:
            raise LMDBError("Write transaction already active")
        return _new_write_txn()

    def request_write(done: action(?Exception, ?WriteTransaction) -> None) -> None:
        """Request a write transaction

        Requests are granted in FIFO order. If no writer is active, the callback
        is invoked immediately with a fresh WriteTransaction. Otherwise it is
        queued until the current writer commits or aborts. The callback is
        invoked with either a WriteTransaction or an Exception.
        """
        if not _is_open:
            done(LMDBError("Database is closed"), None)
            return
        _write_txn_waiters.append(done)
        _dispatch_waiting_write_txn()

    def get_max_key_size() -> int:
        return _max_key_size

actor ReadTransaction(env: int, dbi: int, release_fn: action() -> None):
    """Read-only transaction - multiple allowed concurrently
    """
    var _txn: int = 0
    var _committed: bool = False
    var _aborted: bool = False
    var _dbi: int = dbi
    var _release_fn: action() -> None = release_fn
    var _released: bool = False
    var _cursors: list[ReadCursor] = []

    _txn = _txn_begin_read(env)

    def get(key: bytes) -> ?bytes:
        if _committed or _aborted:
            raise LMDBError("Transaction already finished")
        return _txn_get(_txn, _dbi, key)

    def cursor() -> ReadCursor:
        if _committed or _aborted:
            raise LMDBError("Transaction already finished")
        c = ReadCursor(_txn, _dbi)
        _cursors.append(c)
        return c

    def _release_once():
        if _released:
            return
        _released = True
        await async _release_fn()

    def _close_cursors():
        msgs = []
        for c in _cursors:
            msg = async c.close()
            msgs.append(msg)
        for msg in msgs:
            await msg
        _cursors = []

    def commit():
        if _committed:
            return # Idempotent noop
        if _aborted:
            raise LMDBError("Transaction already aborted")
        commit_started = False
        try:
            _close_cursors()
            commit_started = True
            _txn_commit(_txn)
            _committed = True
        except Exception as e:
            if not commit_started:
                _txn_abort(_txn)
            _aborted = True
            _release_once()
            raise e
        _release_once()

    def abort():
        if _aborted:
            return # Idempotent noop
        if _committed:
            raise LMDBError("Transaction already committed")
        try:
            _close_cursors()
        except Exception as e:
            _txn_abort(_txn)
            _aborted = True
            _release_once()
            raise e
        _txn_abort(_txn)
        _aborted = True
        _release_once()

    def __cleanup__():
        if not _committed and not _aborted:
            abort()

actor WriteTransaction(env: int, dbi: int, max_key_size: int, release_fn: action() -> None):
    """Read-write transaction - only one allowed at a time"""
    var _txn: int = 0
    var _committed: bool = False
    var _aborted: bool = False
    var _dbi: int = dbi
    var _max_key_size: int = max_key_size
    var _release_fn: action() -> None = release_fn
    var _released: bool = False
    var _cursors: list[WriteCursor] = []
    var _affinity_wtid: int = 0

    proc def _pin_affinity() -> int:
        NotImplemented
    _affinity_wtid = _pin_affinity()

    _txn = _txn_begin_write(env)

    def put(key: bytes, value: bytes):
        if _committed or _aborted:
            raise LMDBError("Transaction already finished")
        if len(key) > _max_key_size:
            raise LMDBKeySizeError(key, _max_key_size)
        _txn_put(_txn, _dbi, key, value)

    def get(key: bytes) -> ?bytes:
        if _committed or _aborted:
            raise LMDBError("Transaction already finished")
        if len(key) > _max_key_size:
            raise LMDBKeySizeError(key, _max_key_size)
        return _txn_get(_txn, _dbi, key)

    def delete(key: bytes) -> bool:
        if _committed or _aborted:
            raise LMDBError("Transaction already finished")
        if len(key) > _max_key_size:
            raise LMDBKeySizeError(key, _max_key_size)
        return _txn_delete(_txn, _dbi, key)

    def cursor() -> WriteCursor:
        if _committed or _aborted:
            raise LMDBError("Transaction already finished")
        c = WriteCursor(_txn, _dbi, _affinity_wtid)
        _cursors.append(c)
        return c

    def _release_once():
        if _released:
            return
        _released = True
        await async _release_fn()

    def _close_cursors():
        msgs = []
        for c in _cursors:
            msg = async c.close()
            msgs.append(msg)
        for msg in msgs:
            await msg
        _cursors = []

    def commit():
        if _committed:
            return # Idempotent noop
        if _aborted:
            raise LMDBError("Transaction already aborted")
        commit_started = False
        try:
            _close_cursors()
            commit_started = True
            _txn_commit(_txn)
            _committed = True
        except Exception as e:
            if not commit_started:
                _txn_abort(_txn)
            _aborted = True
            _release_once()
            raise e
        _release_once()

    def abort():
        if _aborted:
            return # Idempotent noop
        if _committed:
            raise LMDBError("Transaction already committed")
        try:
            _close_cursors()
        except Exception as e:
            _txn_abort(_txn)
            _aborted = True
            _release_once()
            raise e
        _txn_abort(_txn)
        _aborted = True
        _release_once()

    def __cleanup__():
        if not _committed and not _aborted:
            abort()

actor ReadCursor(txn_ptr: int, dbi: int):
    """Cursor for read-only iteration over database"""
    var _cursor: int = 0
    var _valid: bool = True

    _cursor = _cursor_open(txn_ptr, dbi)

    def close():
        if _cursor != 0:
            _cursor_close(_cursor)
            _cursor = 0
        _valid = False

    def mark_invalid():
        close()

    def _check_valid():
        if not _valid:
            raise LMDBError("Cursor is no longer valid - transaction has ended")

    def first() -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_first(_cursor)

    def last() -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_last(_cursor)

    def next() -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_next(_cursor)

    def prev() -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_prev(_cursor)

    def seek(key: bytes) -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_seek(_cursor, key)

    def seek_prefix(prefix: bytes) -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_seek_prefix(_cursor, prefix)

    def __cleanup__():
        close()

actor WriteCursor(txn_ptr: int, dbi: int, affinity_wtid: int):
    """Cursor for read-write iteration and modification"""
    var _cursor: int = 0
    var _txn_ptr: int = txn_ptr
    var _dbi: int = dbi
    var _valid: bool = True

    proc def _set_affinity(wtid: int) -> None:
        NotImplemented
    _set_affinity(affinity_wtid)

    def _ensure_open():
        if _cursor == 0:
            _cursor = _cursor_open(_txn_ptr, _dbi)

    def close():
        if _cursor != 0:
            _cursor_close(_cursor)
            _cursor = 0
        _valid = False

    def mark_invalid():
        close()

    def _check_valid():
        if not _valid:
            raise LMDBError("Cursor is no longer valid - transaction has ended")
        _ensure_open()

    def first() -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_first(_cursor)

    def last() -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_last(_cursor)

    def next() -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_next(_cursor)

    def prev() -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_prev(_cursor)

    def seek(key: bytes) -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_seek(_cursor, key)

    def seek_prefix(prefix: bytes) -> ?(key: bytes, value: bytes):
        _check_valid()
        return _cursor_seek_prefix(_cursor, prefix)

    def put(key: bytes, value: bytes):
        _check_valid()
        _cursor_put(_cursor, key, value)

    def delete():
        _check_valid()
        _cursor_delete(_cursor)

    def __cleanup__():
        close()


# C extension functions (implemented in lib.ext.c)
