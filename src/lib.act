    NotImplemented

def _txn_put(txn: int, dbi: int, key: bytes, value: bytes) -> None:
    NotImplemented

def _txn_get(txn: int, dbi: int, key: bytes) -> ?bytes:
    NotImplemented

def _txn_delete(txn: int, dbi: int, key: bytes) -> bool:
    NotImplemented

def _cursor_open(txn: int, dbi: int) -> int:
    NotImplemented

